{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Poke Radar",
  "version": "0.1.0",
  "identifier": "com.pokeradar.app",
  "build": {
    "beforeDevCommand": "node -e \"const fs=require('fs'),path=require('path'),cp=require('child_process');const candidates=[path.resolve('ui'),path.resolve('../ui')];const ui=candidates.find((p)=>fs.existsSync(path.join(p,'package.json')));if(!ui){console.error('UI package.json introuvable');process.exit(1);}const npm=process.platform==='win32'?'npm.cmd':'npm';const r=cp.spawnSync(npm,['--prefix',ui,'run','build'],{stdio:'inherit'});process.exit(r.status??1);\"",
    "beforeBuildCommand": "node -e \"const fs=require('fs'),path=require('path'),cp=require('child_process');const candidates=[path.resolve('ui'),path.resolve('../ui')];const ui=candidates.find((p)=>fs.existsSync(path.join(p,'package.json')));if(!ui){console.error('UI package.json introuvable');process.exit(1);}const npm=process.platform==='win32'?'npm.cmd':'npm';const r=cp.spawnSync(npm,['--prefix',ui,'run','build'],{stdio:'inherit'});process.exit(r.status??1);\"",
    "frontendDist": "../ui-dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Poke Radar",
        "width": 1024,
        "height": 720,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": false
  }
}
