# Poke-Radar environment configuration
# Copy to /etc/poke-radar/env and fill in values

# Auth token for single-user access (required)
POKE_RADAR_AUTH_TOKEN=change-me

# SQLite database path (default: poke-radar.db in working directory)
# DATABASE_URL=poke-radar.db

# Telegram bot token for alerts (optional until Epic 5)
# TELEGRAM_BOT_TOKEN=

# Log level: error, warn, info, debug
RUST_LOG=info
